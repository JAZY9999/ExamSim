# --- Étape de build ---
FROM golang:1.26-alpine AS build
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /examsim ./cmd/server

# --- Image finale minimale ---
FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=build /examsim /examsim
EXPOSE 8080
ENTRYPOINT ["/examsim"]
